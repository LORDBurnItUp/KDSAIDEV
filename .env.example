# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase (PostgreSQL) ──────────────────────────────────────
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY=24h

# ── External API ──────────────────────────────────────────────
API_BASE_URL=https://api.example.com
API_KEY=

# ── Discord (GravityClaw Bot) ─────────────────────────────────
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# ── OpenClaw AI Cascade (free first → paid fallback) ──────────
# Tier 1 — FREE
GROQ_API_KEY=          # groq.com — free, ultra-fast (Llama 3.3 70B)
GOOGLE_API_KEY=        # console.cloud.google.com — Gemini 2.0 Flash (free tier)
# Tier 2 — PAID fallback
OPENROUTER_API_KEY=    # openrouter.ai — also has free models
ANTHROPIC_API_KEY=     # anthropic.com — claude-sonnet-4-6 (best quality)
OPENAI_API_KEY=        # openai.com — gpt-4o-mini

# ── Google Keep / OAuth2 ───────────────────────────────────────
# Run: node src/services/googlekeep.js --auth  to get refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Voice ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=    # elevenlabs.io
DEEPGRAM_API_KEY=      # deepgram.com

# ── Ollama (Local Free AI) ─────────────────────────────────────────
# Run: ollama serve  (starts on http://localhost:11434)
# Pull models: ollama pull llama2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# ── Heartbeat (Proactive AI Assistant) ────────────────────────────────
# Set to 'true' to enable heartbeat messages via Discord
HEARTBEAT_ENABLED=true
# Interval in milliseconds (default: 30 minutes = 1800000)
HEARTBEAT_INTERVAL_MS=1800000
